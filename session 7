DELIMITER //

CREATE PROCEDURE contar_pedidos_cliente(
    IN p_cliente_id INT, 
    OUT p_cantidad INT
)
BEGIN
    -- Contamos cuántos pedidos existen para el cliente indicado
    SELECT COUNT(*)
    INTO p_cantidad
    FROM SalesOrder
    WHERE custId = p_cliente_id;
END //

DELIMITER ;
