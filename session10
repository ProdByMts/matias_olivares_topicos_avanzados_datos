DELIMITER //

CREATE PROCEDURE calcular_costo_detalle(
    IN p_detalle_id INT, 
    INOUT p_costo DECIMAL(10,2)
)
BEGIN
    DECLARE v_precio DECIMAL(10,2);
    DECLARE v_cantidad INT;

    -- Manejador de excepciones
    DECLARE EXIT HANDLER FOR NOT FOUND
    BEGIN
        SIGNAL SQLSTATE '45000' 
        SET MESSAGE_TEXT = 'Error: El detalle de pedido no existe.';
    END;

    -- JOIN entre OrderDetail y Product
    SELECT p.unitPrice, d.quantity 
    INTO v_precio, v_cantidad
    FROM OrderDetail d
    JOIN Product p ON d.productId = p.productId
    WHERE d.orderDetailId = p_detalle_id;

    -- Cálculo
    SET p_costo = v_precio * v_cantidad;

END //

DELIMITER ;
