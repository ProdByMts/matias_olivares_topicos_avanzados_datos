DELIMITER //

CREATE PROCEDURE actualizar_total_pedidos(
    IN p_cliente_id INT, 
    IN p_porcentaje DECIMAL(5,2)
)
BEGIN
    -- Declaración de variables
    DECLARE done INT DEFAULT FALSE;
    DECLARE v_pedido_id INT;
    DECLARE v_freight DECIMAL(10,2);
    
    DECLARE pedido_cursor CURSOR FOR 
        SELECT orderId, freight FROM SalesOrder WHERE custId = p_cliente_id;
        
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
    IF p_porcentaje IS NULL THEN
        SET p_porcentaje = 10.00;
    END IF;
    OPEN pedido_cursor;

    read_loop: LOOP
        FETCH pedido_cursor INTO v_pedido_id, v_freight;
        IF done THEN
            LEAVE read_loop;
        END IF;
        UPDATE SalesOrder 
        SET freight = v_freight * (1 + (p_porcentaje / 100))
        WHERE orderId = v_pedido_id;
        
    END LOOP;

    CLOSE pedido_cursor;
    
    SELECT CONCAT('Se han actualizado los pedidos del cliente: ', p_cliente_id) AS Resultado;
    
END //

DELIMITER ;

