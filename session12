DELIMITER //

CREATE TRIGGER validar_cantidad_detalle_insert
BEFORE INSERT ON OrderDetail
FOR EACH ROW
BEGIN
    IF NEW.quantity <= 0 THEN
        SIGNAL SQLSTATE '45000' 
        SET MESSAGE_TEXT = 'Error: La cantidad del detalle debe ser mayor a 0.';
    END IF;
END //

CREATE TRIGGER validar_cantidad_detalle_update
BEFORE UPDATE ON OrderDetail
FOR EACH ROW
BEGIN
    IF NEW.quantity <= 0 THEN
        SIGNAL SQLSTATE '45000' 
        SET MESSAGE_TEXT = 'Error: La cantidad del detalle debe ser mayor a 0.';
    END IF;
END //

DELIMITER ;

