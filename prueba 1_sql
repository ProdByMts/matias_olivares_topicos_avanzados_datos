-- Ejercicio 1: Cursor Explícito con Promedio (20 pts)
DECLARE
    CURSOR c_especialidades IS
        SELECT ag.especialidad, AVG(asi.horas) as promedio_horas
        FROM Agentes ag
        JOIN Asignaciones asi ON ag.agente_id = asi.agente_id
        GROUP BY ag.especialidad
        HAVING AVG(asi.horas) > 30;
        
    v_especialidad Agentes.especialidad%TYPE;
    v_promedio NUMBER;
BEGIN
    OPEN c_especialidades;
    LOOP
        FETCH c_especialidades INTO v_especialidad, v_promedio;
        EXIT WHEN c_especialidades%NOTFOUND;
        
        DBMS_OUTPUT.PUT_LINE('Especialidad: ' || v_especialidad || ' | Promedio Horas: ' || ROUND(v_promedio, 2));
    END LOOP;
    CLOSE c_especialidades;
END;
/


-- Ejercicio 2: Cursor Explícito con FOR UPDATE (20 pts)
DECLARE
    CURSOR c_asignaciones_criticas IS
        SELECT a.horas
        FROM Asignaciones a
        JOIN Incidentes i ON a.incidente_id = i.incidente_id
        WHERE i.severidad = 'Critical'
        FOR UPDATE OF a.horas; -- Bloquea las filas para actualizar
        
    v_horas Asignaciones.horas%TYPE;
BEGIN
    OPEN c_asignaciones_criticas;
    LOOP
        FETCH c_asignaciones_criticas INTO v_horas;
        EXIT WHEN c_asignaciones_criticas%NOTFOUND;
        
        -- Actualiza exactamente la fila donde está apuntando el cursor
        UPDATE Asignaciones
        SET horas = horas + 10
        WHERE CURRENT OF c_asignaciones_criticas;
    END LOOP;
    CLOSE c_asignaciones_criticas;
    
    COMMIT; 
    DBMS_OUTPUT.PUT_LINE('Se aumentaron 10 horas a los incidentes Critical de forma exitosa.');
EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('Error al actualizar: ' || SQLERRM);
END;
/


-- Ejercicio 3: Tipo de Objeto y Transferencia de Datos (20 pts)

-- 3.1 Crear la especificación del Tipo de Objeto
CREATE OR REPLACE TYPE incidente_obj AS OBJECT (
    incidente_id NUMBER,
    descripcion VARCHAR2(200),
    MEMBER FUNCTION get_reporte RETURN VARCHAR2
);
/

-- 3.2 Crear el cuerpo (BODY) del Tipo de Objeto
CREATE OR REPLACE TYPE BODY incidente_obj AS
    MEMBER FUNCTION get_reporte RETURN VARCHAR2 IS
    BEGIN
        RETURN 'Reporte -> ID: ' || SELF.incidente_id || ' | Descripción: ' || SELF.descripcion;
    END get_reporte;
END;
/

-- 3.3 Crear la tabla basada en el Tipo de Objeto
CREATE TABLE tabla_incidentes_obj OF incidente_obj;

-- 3.4 Transferir los datos de la tabla relacional a la tabla de objetos
BEGIN
    INSERT INTO tabla_incidentes_obj
    SELECT incidente_obj(incidente_id, descripcion) FROM Incidentes;
    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Datos transferidos a la tabla de objetos correctamente.');
END;
/

-- 3.5 Cursor explícito para listar usando el método get_reporte
DECLARE
 
    CURSOR c_objetos IS SELECT VALUE(t) FROM tabla_incidentes_obj t;
    v_obj incidente_obj;
BEGIN
    DBMS_OUTPUT.PUT_LINE('--- LISTADO DE OBJETOS ---');
    OPEN c_objetos;
    LOOP
        FETCH c_objetos INTO v_obj;
        EXIT WHEN c_objetos%NOTFOUND;
        
    
        DBMS_OUTPUT.PUT_LINE(v_obj.get_reporte());
    END LOOP;
    CLOSE c_objetos;
END;
/
